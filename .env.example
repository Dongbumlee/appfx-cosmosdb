# Local development configuration template.
# Copy this file to .env and replace placeholder values with non-secret resource identifiers.
COSMOSDB_SQL_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOSDB_SQL_DATABASE=<your-database-name>
COSMOSDB_SQL_CONTAINER=<your-container-name>
COSMOSDB_MONGO_URI=mongodb://<host>:<port>/?tls=true
COSMOSDB_MONGO_DATABASE=<your-database-name>
COSMOSDB_MONGO_COLLECTION=<your-collection-name>